# ============================================================
# AI Humanizer .gitignore
# 策略：黑名单 — 只忽略不需要推送的文件/文件夹
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo

# 虚拟环境
venv/

# 数据库（敏感数据）
instance/
deliverables/

# 用户上传文件
uploads/

# 环境变量（含密钥）
.env

# 工作记忆 / 调试
.workbuddy/
.gstack/
test/

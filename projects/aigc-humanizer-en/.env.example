# ============================================
# AI Humanizer - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Flask secret key (REQUIRED)
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-here

# Flask environment: development | production
FLASK_ENV=development

# ============================================
# Payment Gateway
# ============================================
# Adapter type: mock | alipay
PAYMENT_ADAPTER=mock

# Alipay credentials (required when PAYMENT_ADAPTER=alipay)
ALIPAY_APP_ID=
ALIPAY_PID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# Sandbox: https://openapi-sandbox.dl.alipaydev.com/gateway.do
# Production: https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-domain.com/api/webhook/alipay
ALIPAY_RETURN_URL=https://your-domain.com/orders

# ============================================
# Humanizer Engine
# ============================================
# Adapter type: rule_based | api
HUMANIZER_ADAPTER=rule_based

# ai-text-humanizer.com credentials (required when HUMANIZER_ADAPTER=api)
AI_TEXT_HUMANIZER_EMAIL=
AI_TEXT_HUMANIZER_PASSWORD=

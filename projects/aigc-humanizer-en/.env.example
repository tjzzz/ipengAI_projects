# Environment variables for AI Humanizer
# Copy this file to .env and fill in the values

# Flask secret key (REQUIRED for session security)
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secure-secret-key-change-this-in-production

# Payment adapter configuration
# Set to 'alipay' in production, 'mock' for development/testing
PAYMENT_ADAPTER=mock  # mock or alipay
HUMANIZER_ADAPTER=rule_based  # rule_based or api

# ══════════════════════════════════════════════════
# ai-text-humanizer.com API (REQUIRED if HUMANIZER_ADAPTER=api)
# ══════════════════════════════════════════════════
# Register at https://ai-text-humanizer.com and purchase PRO plan
AI_TEXT_HUMANIZER_EMAIL=
AI_TEXT_HUMANIZER_PASSWORD=

# ══════════════════════════════════════════════════
# Alipay configuration (REQUIRED if PAYMENT_ADAPTER=alipay)
# ══════════════════════════════════════════════════
# Get these from Alipay Open Platform: https://open.alipay.com
# Sandbox: https://open.alipay.com/platform/developerIndex.htm
ALIPAY_APP_ID=your_app_id

# PID = 商户合作者身份 ID（卖家 ID）
# 在开放平台 → 账号管理中获取，格式如 2088xxxxxxxx
ALIPAY_PID=your_pid

# ── RSA 密钥说明 ──
# 支付宝使用 RSA2(SHA-256) 签名，需要在开放平台配置应用公钥
# 然后在 .env 中填入应用私钥和支付宝公钥（两者不同）
#
# 格式：将 PEM 文件的内容去掉 -----BEGIN/END----- 标记后合并为一行
# 示例（替换成你自己的密钥）：
#   ALIPAY_PRIVATE_KEY=MIIEpAIBAAKCAQEA...
#   ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
#
# 生成密钥对：openssl genrsa -out app_private_key.pem 2048
# 提取公钥：openssl rsa -in app_private_key.pem -pubout -out app_public_key.pem
# 在开放平台上传 app_public_key.pem，然后获取「支付宝公钥」
#
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ── 网关地址 ──
# ⚡ 测试（沙箱）：https://openapi.alipaydev.com/gateway.do
# 🚀 生产环境：https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY_URL=https://openapi.alipaydev.com/gateway.do

# ── 异步通知地址 ──
# Webhook URL 必须可公开访问的 HTTPS 地址
# 本地开发用 ngrok：ngrok http 5000
ALIPAY_NOTIFY_URL=https://your-domain.com/api/webhook/alipay
ALIPAY_RETURN_URL=https://your-domain.com/orders

# Pricing (optional, defaults applied if not set)
# PRICE_PER_1000_WORDS=14.9
# MAX_FREE_ANALYSIS_WORDS=600
# FREE_WORD_LIMIT=300

# Upload configuration
# MAX_CONTENT_LENGTH=10485760  # 10MB in bytes
# UPLOAD_FOLDER=uploads/
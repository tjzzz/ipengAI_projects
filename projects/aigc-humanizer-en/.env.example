# Environment variables for AI Humanizer
# Copy this file to .env and fill in the values

# Flask secret key (REQUIRED for session security)
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secure-secret-key-change-this-in-production

# Payment adapter configuration
# Set to 'alipay' in production, 'mock' for development/testing
PAYMENT_ADAPTER=mock  # mock or alipay
HUMANIZER_ADAPTER=rule_based  # rule_based or api

# Alipay configuration (REQUIRED if PAYMENT_ADAPTER=alipay)
# Get these from Alipay Open Platform: https://open.alipay.com
ALIPAY_APP_ID=your_app_id
ALIPAY_PID=your_pid
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# Webhook URL must be publicly accessible (HTTPS) for Alipay callbacks
ALIPAY_NOTIFY_URL=https://your-domain.com/api/webhook/alipay
ALIPAY_RETURN_URL=https://your-domain.com/orders

# Pricing (optional, defaults applied if not set)
# PRICE_PER_1000_WORDS=14.9
# MAX_FREE_ANALYSIS_WORDS=600
# FREE_WORD_LIMIT=300

# Upload configuration
# MAX_CONTENT_LENGTH=10485760  # 10MB in bytes
# UPLOAD_FOLDER=uploads/
